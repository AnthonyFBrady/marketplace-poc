# Copy this file to .env.local and fill in values before running locally.
# Never commit .env.local — it is in .gitignore.

# Map tiles
# Current provider: OpenFreeMap (no key required)
# NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/positron

# Database — Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Payments — Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Analytics — PostHog (swap key/host for Mixpanel or Segment)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Netlify — set as GitHub Actions secrets, not here
# NETLIFY_AUTH_TOKEN=
# NETLIFY_SITE_ID=
